# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://b2buser:yourpassword@db:5432/b2bportal
# For local dev (no Docker):
# DATABASE_URL=postgresql://youruser:yourpassword@localhost:5432/b2bportal_dev

# ─── Authentication ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-very-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=8h

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://portal.yourdomain.com
# Local dev:
# ALLOWED_ORIGIN=http://localhost:5173

# ─── (Future) Email ─────────────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com
